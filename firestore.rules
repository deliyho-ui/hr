rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /candidates/{candidateId} {
      allow create: if isValidLandingCreate(candidateId);
      allow read, update: if isSignedInRecruiter();
      allow delete: if false;
    }

    match /settings/{documentId} {
      allow read, write: if isSignedInRecruiter();
    }

    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedInRecruiter() {
      return request.auth != null;
    }

    function isValidLandingCreate(candidateId) {
      let data = request.resource.data;
      return data.candidateId == candidateId
        && data.source == "qr-landing-page"
        && data.status == "new"
        && data.fullName is string
        && data.fullName.size() >= 2
        && data.fullName.size() <= 120
        && data.phone is string
        && data.phone.size() >= 8
        && data.phone.size() <= 30
        && data.email is string
        && data.email.size() <= 160
        && data.city is string
        && data.city.size() <= 80
        && data.age is number
        && data.age >= 18
        && data.age <= 65
        && data.availability is string
        && data.securityBackground is string
        && data.drivingLicense is string
        && data.answers is map
        && data.answers.motivation is string
        && data.answers.motivation.size() <= 2000
        && data.answers.experience is string
        && data.answers.experience.size() <= 2000
        && data.cvFile is map
        && data.cvFile.name is string
        && data.cvFile.type is string
        && data.cvFile.size is number
        && data.cvFile.size <= 8 * 1024 * 1024
        && data.cvFile.storagePath is string
        && data.cvFile.storagePath.matches("^candidate-cvs/" + candidateId + "/.*");
    }
  }
}
